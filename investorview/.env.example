# Variable REFERENCE only — do NOT put real values here and do NOT create a .env
# with secrets. Secrets live ONLY in Railway → Variables (SpendBot pattern).
# For local dev, inject them at runtime with the Railway CLI: `railway run ...`.
# Values below are left blank on purpose; non-secret defaults are shown.

# ---- Shared ----
ANTHROPIC_API_KEY=            # set in Railway Variables only
CLAUDE_MODEL=claude-sonnet-4-20250514
DEFAULT_LANG=id              # id (default) | en

# ---- Python analysis backend ----
PORT=                        # injected by Railway

# ---- Node Telegram bot ----
TELEGRAM_BOT_TOKEN=          # set in Railway Variables only
ANTHROPIC_API_KEY=           # set in Railway Variables only
# Reference the backend service URL via Railway vars instead of hardcoding:
#   ANALYSIS_BACKEND_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}
ANALYSIS_BACKEND_URL=
SUBSCRIBER_CHAT_IDS=          # comma-separated chat ids for scheduled broadcasts
WATCHLIST=BBRI,TLKM,BBCA

# Per-market UTC offsets for the scheduler (manual DST, like SpendBot)
TZ_OFFSET_IDX=7
TZ_OFFSET_EU=2
TZ_OFFSET_US=-4
